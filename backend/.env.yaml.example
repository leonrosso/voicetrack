# VoiceTrack (Diethropic) — Variabili d'ambiente per il deploy
# Copia questo file in .env.yaml e inserisci le tue credenziali reali.
# NON committare mai .env.yaml (è già in .gitignore).

# API key per proteggere la Cloud Function (inventane una casuale)
# Generala con: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
VOICETRACK_API_KEY: "INSERISCI_QUI"

# Anthropic API key
ANTHROPIC_API_KEY: "sk-ant-INSERISCI_QUI"

# Provider LLM
LLM_PROVIDER: "claude"

# Modello Claude
CLAUDE_MODEL: "claude-sonnet-5"

# Google Sheets — ID del tuo foglio
SPREADSHEET_ID: "INSERISCI_QUI"

# Nome del foglio (tab)
SHEET_NAME: "diethropic"

# Credenziali Service Account — incolla qui il JSON INTERO su una riga
GOOGLE_CREDENTIALS_JSON: 'INSERISCI_QUI'
